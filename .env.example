# ─── Supabase (obligatorio) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Marca / App (opcional, tienen fallback en brand.ts) ─────────────────────
VITE_APP_NAME=Shelwi
VITE_APP_SHORT_NAME=Shelwi
VITE_APP_SLOGAN=Cotiza · Gestiona · Crece
VITE_APP_TAGLINE=Cotiza. Gestiona. Crece.
VITE_APP_URL=https://ktz-360.vercel.app
VITE_APP_SUPPORT_EMAIL=soporte@shelwi.com
VITE_COMPANY_NAME=Shelwi

# ─── OAuth integraciones (Google Calendar / Outlook Calendar) ─────────────────
# Obtener en: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Obtener en: portal.azure.com → Microsoft Entra ID → App Registrations
VITE_OUTLOOK_CLIENT_ID=your-azure-application-client-id

# ─── Secrets de Edge Functions (se configuran en Supabase Dashboard, NO aquí) ─
# Supabase Dashboard → Edge Functions → Manage Secrets:
# APP_URL                     = https://ktz-360.vercel.app
# GOOGLE_CLIENT_ID            = igual que VITE_GOOGLE_CLIENT_ID
# GOOGLE_CLIENT_SECRET        = obtener de Google Cloud Console
# OUTLOOK_CLIENT_ID           = igual que VITE_OUTLOOK_CLIENT_ID
# OUTLOOK_CLIENT_SECRET       = obtener de Microsoft Entra
# INTEGRATION_ENCRYPTION_KEY  = generar con: openssl rand -hex 32
